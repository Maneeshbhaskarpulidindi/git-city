{
  "name": "gitcity",
  "displayName": "Git City",
  "description": "Make your Git City building glow when you code. Privacy-first: you control exactly what gets shared.",
  "version": "0.1.0",
  "publisher": "gitcity",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "icon": "icon.png",
  "contributes": {
    "commands": [
      {
        "command": "gitCity.login",
        "title": "Git City: Set API Key"
      },
      {
        "command": "gitCity.logout",
        "title": "Git City: Remove API Key"
      },
      {
        "command": "gitCity.togglePause",
        "title": "Git City: Toggle Tracking"
      },
      {
        "command": "gitCity.showDashboard",
        "title": "Git City: Open Dashboard"
      }
    ],
    "configuration": {
      "title": "Git City",
      "properties": {
        "gitCity.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable activity tracking"
        },
        "gitCity.apiUrl": {
          "type": "string",
          "default": "https://thegitcity.com",
          "description": "Git City API URL (changing this sends your API key to a different server)",
          "scope": "application"
        },
        "gitCity.privacy.shareLanguage": {
          "type": "boolean",
          "default": true,
          "description": "Share the programming language you're using (shown publicly on your building)"
        },
        "gitCity.privacy.shareProject": {
          "type": "boolean",
          "default": true,
          "description": "Send project name for your personal analytics (never shown publicly to other users)"
        },
        "gitCity.privacy.excludeProjects": {
          "type": "array",
          "default": [],
          "items": { "type": "string" },
          "description": "Project names to never track at all (e.g. secret-project, client-work)"
        },
        "gitCity.idleTimeout": {
          "type": "number",
          "default": 300,
          "minimum": 60,
          "maximum": 3600,
          "description": "Seconds of inactivity before marking as idle"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
